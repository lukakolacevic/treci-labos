@model PagedResult<Lokacija>
@{
    ViewData["Title"] = "Lokacije";
    var pretraga = ViewBag.Pretraga as string;
}

<div class="d-flex justify-content-between align-items-center mb-3">
    <h1 class="h3 mb-0">Lokacije lanca</h1>
    <a asp-action="Create" class="btn btn-success">+ Nova lokacija</a>
</div>
<p class="text-muted">
    Složeni (master-detail) ekran. Odaberite lokaciju za upravljanje zalihama sastojaka.
</p>

<form method="get" class="row g-2 mb-3">
    <div class="col-sm-6 col-md-4">
        <input type="text" name="pretraga" value="@pretraga" class="form-control"
               placeholder="Pretraži po nazivu, gradu ili adresi" />
    </div>
    <div class="col-auto">
        <button type="submit" class="btn btn-primary">Traži</button>
        <a asp-action="Index" class="btn btn-outline-secondary">Poništi</a>
    </div>
</form>

@if (Model.UkupnoZapisa == 0)
{
    <div class="alert alert-info">Nema pronađenih lokacija.</div>
}
else
{
    <table class="table table-striped table-hover align-middle">
        <thead>
            <tr>
                <th>Naziv</th>
                <th>Grad</th>
                <th>Tip objekta</th>
                <th>Voditelj</th>
                <th>Status</th>
                <th class="text-end">Akcija</th>
            </tr>
        </thead>
        <tbody>
            @foreach (var l in Model.Stavke)
            {
                <tr>
                    <td>@l.Naziv</td>
                    <td>@l.Grad</td>
                    <td>@l.TipObjekta</td>
                    <td>@(l.Voditelj?.PunoIme ?? "-")</td>
                    <td>
                        @if (l.Aktivna)
                        {
                            <span class="badge bg-success">Aktivna</span>
                        }
                        else
                        {
                            <span class="badge bg-secondary">Neaktivna</span>
                        }
                    </td>
                    <td class="text-end">
                        <a asp-action="Details" asp-route-id="@l.Id" class="btn btn-sm btn-outline-primary">
                            Otvori detalje
                        </a>
                    </td>
                </tr>
            }
        </tbody>
    </table>

    <div class="d-flex justify-content-between align-items-center">
        <small class="text-muted">Ukupno zapisa: @Model.UkupnoZapisa</small>
        <nav>
            <ul class="pagination mb-0">
                <li class="page-item @(Model.ImaPrethodnu ? "" : "disabled")">
                    <a class="page-link" asp-action="Index" asp-route-pretraga="@pretraga"
                       asp-route-stranica="@(Model.Stranica - 1)">Prethodna</a>
                </li>
                <li class="page-item disabled">
                    <span class="page-link">Stranica @Model.Stranica / @Model.UkupnoStranica</span>
                </li>
                <li class="page-item @(Model.ImaSljedecu ? "" : "disabled")">
                    <a class="page-link" asp-action="Index" asp-route-pretraga="@pretraga"
                       asp-route-stranica="@(Model.Stranica + 1)">Sljedeća</a>
                </li>
            </ul>
        </nav>
    </div>
}
