@model ZalihaSastojkaViewModel
@{
    ViewData["Title"] = "Uredi stavku zalihe";
}

<h1 class="h3 mb-1">Uredi stavku zalihe</h1>
<p class="text-muted">Lokacija: <strong>@ViewBag.NazivLokacije</strong></p>

<div class="card" style="max-width: 720px;">
    <div class="card-body">
        <form asp-action="UrediZalihu" method="post">
            <div asp-validation-summary="ModelOnly" class="text-danger"></div>
            <input type="hidden" asp-for="Id" />
            <partial name="_ZalihaForm" model="Model" />
            <div class="mt-4">
                <button type="submit" class="btn btn-primary">Spremi</button>
                <a asp-action="Details" asp-route-id="@Model.LokacijaId" class="btn btn-outline-secondary">Odustani</a>
            </div>
        </form>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
