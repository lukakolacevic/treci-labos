@*
    Djelomični prikaz (partial) - polja retka detalja (stavke zalihe).
    Koristi se za dodavanje stavke na ekranu Details i za uređivanje na UrediZalihu.
    Skriveni Id (kod uređivanja) dodaje nadređeni prikaz - ovdje ga namjerno nema.
*@
@model ZalihaSastojkaViewModel

<input type="hidden" asp-for="LokacijaId" />
<div class="row g-3">
    <div class="col-md-5">
        @* Padajuća lista za odabir stranog ključa u DETALJIMA složenog ekrana. *@
        <label asp-for="SastojakId" class="form-label"></label>
        <select asp-for="SastojakId" asp-items="@(ViewBag.Sastojci as SelectList)" class="form-select">
            <option value="">-- odaberite sastojak --</option>
        </select>
        <span asp-validation-for="SastojakId" class="text-danger"></span>
    </div>
    <div class="col-md-3">
        <label asp-for="Kolicina" class="form-label"></label>
        <input asp-for="Kolicina" type="number" step="0.01" min="0" class="form-control" />
        <span asp-validation-for="Kolicina" class="text-danger"></span>
    </div>
    <div class="col-md-3">
        <label asp-for="MinimalnaRazina" class="form-label"></label>
        <input asp-for="MinimalnaRazina" type="number" step="0.01" min="0" class="form-control" />
        <span asp-validation-for="MinimalnaRazina" class="text-danger"></span>
    </div>
</div>
